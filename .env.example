# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
ENVIRONMENT=development  # development | production

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=DEBUG  # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# EXTERNAL APIs
# =============================================================================

# Moxfield API
MOXFIELD_API_BASE_URL=https://api2.moxfield.com
MOXFIELD_REFERER=https://moxfield.com/
MOXFIELD_ORIGIN=https://moxfield.com
MOXFIELD_TIMEOUT_MS=30000

# Scryfall API
SCRYFALL_API_BASE_URL=https://api.scryfall.com
SCRYFALL_IMAGE_BASE_URL=https://cards.scryfall.io/normal
SCRYFALL_TIMEOUT_SECONDS=5
SCRYFALL_MAX_RETRIES=2

# Commander Spellbook API
COMMANDER_SPELLBOOK_API_BASE_URL=https://backend.commanderspellbook.com
COMMANDER_SPELLBOOK_WEB_BASE_URL=https://commanderspellbook.com
COMMANDER_SPELLBOOK_TIMEOUT_SECONDS=30

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_DECK_TTL=300        # Time to live for deck cache (seconds)
CACHE_ORACLE_TTL=3600     # Time to live for oracle ID cache (seconds)

# =============================================================================
# BROWSER POOL (Playwright)
# =============================================================================
BROWSER_POOL_MAX_USES=50  # Max uses before browser restart

# =============================================================================
# HTTP CLIENT
# =============================================================================
HTTP_CLIENT_TIMEOUT=30             # Default timeout for HTTP requests (seconds)
HTTP_CLIENT_MAX_KEEPALIVE=20       # Max keepalive connections
HTTP_CLIENT_MAX_CONNECTIONS=100    # Max total connections

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ALLOW_ORIGINS=*               # Comma-separated list or * for all
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=86400
